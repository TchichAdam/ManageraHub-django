# Copy this file to .env and fill in real values. NEVER commit the real .env.

# ── Django core (set these in your host's environment for production) ─────────
# Generate a fresh secret key for production, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
SECRET_KEY=change-me-in-production
# Must be False in production:
DEBUG=True
# Comma-separated hostnames the site is served on:
ALLOWED_HOSTS=localhost,127.0.0.1
# Required in production behind HTTPS, comma-separated, include scheme:
CSRF_TRUSTED_ORIGINS=https://your-domain.com
# Keep HSTS at 0 until your production HTTPS domain is confirmed working.
SECURE_HSTS_SECONDS=0
SECURE_SSL_REDIRECT=True

# ── Database ──────────────────────────────────────────────────────────────────
# Preferred on hosted platforms: set DATABASE_URL for Postgres.
# Example: postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# Leave DB_NAME empty to use local SQLite (db.sqlite3).
# Set DB_NAME (and the rest) to use MySQL instead of DATABASE_URL.
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# ── Email (used by candidate status-change notifications) ─────────────────────
# For local testing without SMTP, use the console backend:
#   EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USE_TLS=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# ── Social login (optional; requires requirements-optional.txt) ───────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
